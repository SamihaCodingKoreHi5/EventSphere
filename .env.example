# Core App Configurations
PROJECT_NAME=EventSphere
API_V1_STR=/api/v1
SECRET_KEY=supersecretkeythatsshouldbechangedinproduction12345!@#
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configurations
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=eventsphere
POSTGRES_PORT=5432

# Email Configurations (Options: console, smtp, resend)
EMAIL_BACKEND=console
EMAIL_FROM=noreply@eventsphere.com

# SMTP Settings (if EMAIL_BACKEND=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Resend Settings (if EMAIL_BACKEND=resend)
RESEND_API_KEY=re_123456789
