# Core App Configurations
PROJECT_NAME=EventSphere
API_V1_STR=/api/v1
SECRET_KEY=dev_secret_key_change_me_in_production_987654321
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configurations
# Default to SQLite for zero-setup local execution:
DATABASE_URL=sqlite:///./eventsphere.db

# To use PostgreSQL, comment out the line above and configure the parameters below:
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=eventsphere
POSTGRES_PORT=5432

# Email Configurations (Options: console, smtp, resend)
EMAIL_BACKEND=console
EMAIL_FROM=noreply@eventsphere.com
